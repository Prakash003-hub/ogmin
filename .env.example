# Optional but recommended for production: your canonical deployed domain.
# Used to build absolute og:image / og:url values social crawlers require.
# Without this, VERCEL_URL is used automatically on Vercel deployments.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Production storage on Vercel (optional but required for persistence) ---
# The app works locally with data/og-links.json + public/og/ with zero config.
# On Vercel, the filesystem is read-only/ephemeral, so for production add:
#
# 1) Vercel KV (or any Upstash-Redis-compatible store) for link records.
#    Add "KV" from the Vercel Storage tab and these are auto-populated:
KV_REST_API_URL=
KV_REST_API_TOKEN=

# 2) Vercel Blob for uploaded OG images.
#    Add "Blob" from the Vercel Storage tab and this is auto-populated:
BLOB_READ_WRITE_TOKEN=
